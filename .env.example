# Copy this file to .env and fill in your keys
# Never commit .env to GitHub — it's in .gitignore

# Get from: apify.com → Settings → Integrations → API token
# Used once to scrape tweets. ~$5-15 for 2,000 tweets.
APIFY_API_TOKEN=your_apify_token_here

# Get from: console.anthropic.com → API keys
# Used for generating styled output via Claude
# Note: your claude.ai subscription does NOT cover API access — this is separate
ANTHROPIC_API_KEY=your_anthropic_key_here
